{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["src/main/**/*", "src/preload/**/*", "shared/**/*", "config/**/*"]
}
