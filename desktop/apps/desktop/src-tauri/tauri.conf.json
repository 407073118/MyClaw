{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyClaw",
  "version": "0.1.0",
  "identifier": "com.example.myclawdesktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build && pnpm run build:runtime-sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyClaw",
        "width": 1440,
        "height": 920
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/myclaw-runtime-x86_64-pc-windows-msvc.exe"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    },
    "targets": "all"
  }
}
