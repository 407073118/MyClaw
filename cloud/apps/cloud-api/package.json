{
  "name": "@myclaw-cloud/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "sync:shared": "pnpm --dir ../../packages/shared build",
    "predev": "pnpm run sync:shared",
    "dev": "nest start --watch",
    "prebuild": "pnpm run sync:shared",
    "build": "tsc -p tsconfig.json --noEmit",
    "bundle": "node scripts/bundle.mjs",
    "pretest": "pnpm run sync:shared",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "pnpm exec tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@myclaw-cloud/shared": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/node": "^22.13.10",
    "esbuild": "^0.27.4",
    "prisma": "^6.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
