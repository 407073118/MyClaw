# 服务端口
PORT=43210

# 会话签名密钥
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-too

# 数据库连接信息
# 下面四个字段主要用于人工填写和核对，当前程序真正读取的是 DATABASE_URL
DB_HOST=192.168.162.82
DB_PORT=3306
DB_NAME=myclaw_cloud
DB_USER=root
DB_PASSWORD=123456

# Prisma / cloud-api 当前使用的数据库连接串
DATABASE_URL=mysql://root:123456@192.168.162.82:3306/myclaw_cloud

# FastDFS 基础地址
FASTDFS_BASE_URL=http://127.0.0.1:8080
FASTDFS_PROJECT_CODE=BrTest
FASTDFS_TOKEN=BrTest20210526
FASTDFS_UPLOAD_PATH=/api/file/uploadSingle
FASTDFS_DOWNLOAD_PATH=/api/file/download
FASTDFS_TIMEOUT_MS=30000

# 内部登录接口
INTERNAL_AUTH_BASE_URL=http://127.0.0.1:9000
INTERNAL_AUTH_TIMEOUT_MS=5000
INTERNAL_AUTH_MODE=auto
INTERNAL_AUTH_VALIDATE_PATH=/api/cas/validateUser
# CAS 统一认证地址，优先级高于 INTERNAL_AUTH_VALIDATE_URL
# CAS_VALIDATE_USER_URL=
# INTERNAL_AUTH_VALIDATE_URL 可覆盖 baseUrl + path 的组合
# INTERNAL_AUTH_VALIDATE_URL=http://127.0.0.1:9000/api/cas/validateUser
# 需要角色准入时可配置，例如：admin,cloud-user
INTERNAL_AUTH_REQUIRED_ROLES=
